<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. Compose drives the real theming; this keeps the
         system window backgrounds paper-coloured before Compose takes over. -->
    <style name="Theme.Folio" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:navigationBarColor">@color/paper</item>
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <style name="Theme.Folio.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/paper</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Folio</item>
    </style>
</resources>
